# ── NetGuard AI — Environment Variables ──────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Required: Your Anthropic API key
ANTHROPIC_API_KEY=your_api_key_here

# Network interface to monitor (eth0, en0, wlan0, Wi-Fi, etc.)
NETWORK_INTERFACE=eth0

# Number of packets to capture per scan
PACKET_COUNT=100

# Set to "false" in production to use real packet capture (requires root/sudo)
DEV_MODE=true

# Comma-separated list of trusted internal IPs (won't trigger moderate-activity alerts)
INTERNAL_IPS=192.168.1.1,192.168.1.2,10.0.0.1

# Port the Flask server listens on
PORT=5000
